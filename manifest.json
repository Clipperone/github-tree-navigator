{
  "manifest_version": 3,
  "name": "GitHub Tree Navigator",
  "version": "1.0.0",
  "description": "Navigate any GitHub repository like a pro. Browse file trees without page reloads, making your workflow faster and smoother.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*"
      ],
      "js": [
        "src/inject_start.ts"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://github.com/*/*"
      ],
      "js": [
        "src/content_script.ts"
      ],
      "css": [
        "src/styles/sidebar.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "src/icons/icon16.png",
    "32":  "src/icons/icon32.png",
    "48":  "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "action": {
    "default_title": "GitHub Tree Navigator",
    "default_icon": {
      "16":  "src/icons/icon16.png",
      "32":  "src/icons/icon32.png",
      "48":  "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  }
}
